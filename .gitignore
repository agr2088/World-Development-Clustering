# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Data files — raw & processed ─────────────────────────────────────────────
data/raw/
data/processed/*.csv
data/processed/*.pkl
data/processed/*.parquet

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Trained models ────────────────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.h5

!models/.gitkeep

# ── Reports & figures ─────────────────────────────────────────────────────────
reports/figures/
reports/*.png
reports/*.jpg
reports/*.svg
reports/*.html

# Keep CSVs and JSON in reports (small, version-worthy)
# reports/*.csv  ← intentionally tracked
# reports/evaluation_metrics.json  ← intentionally tracked

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig